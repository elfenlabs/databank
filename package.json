{
  "name": "@elfenlabs/thesauros",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "mcp": "bun run src/mcp.ts",
    "migrate": "dbmate --no-dump-schema up",
    "migrate:new": "dbmate new",
    "test": "bun test tests/unit",
    "test:e2e": "bun test tests/e2e --timeout 60000",
    "test:types": "bunx tsc --noEmit",
    "check": "bun run test:types && bun run test && bun run test:e2e"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.18.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "graphql": "^16.13.0",
    "graphql-yoga": "^5.18.0",
    "kysely": "^0.28.11",
    "pg": "^8.19.0"
  }
}